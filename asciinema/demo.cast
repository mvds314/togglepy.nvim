38;2;86;92;100m\u001b[48;2;30;34;42m(\"Let's debug something\")\u001b(B\u001b[m\u001b[38;2;171;178;191m\u001b[48;2;30;34;42m                                                                                                                     \u001b[14;13H                                                                                                                                              \u001b[15;13H\u001b(B\u001b[m\u001b[38;2;86;92;100m\u001b[48;2;30;34;42m(\"Use ipdab to connect ipdb/pdb to Neovim's debugger.\")\u001b(B\u001b[m\u001b[38;2;171;178;191m\u001b[48;2;30;34;42m                                                                                       \u001b[16;13H                                                                                                                                              \u001b[17;13H\u001b(B\u001b[m\u001b[38;2;86;92;100m\u001b[48;2;30;34;42m(\"It's wrapper around ipdab/pdb that starts a DAP server.\")\u001b(B\u001b[m\u001b[38;2;171;178;191m\u001b[48;2;30;34;42m                                                                                   \u001b[18;13H                                                                                                                                              \u001b[19;13H\u001b(B\u001b[m\u001b[38;2;86;92;100m\u001b[48;2;30;34;42m(\"Use next/continue/step in the terminal\")\u001b(B\u001b[m\u001b[38;2;171;178;191m\u001b[48;2;30;34;42m                                                                                                    \u001b[20;13H                                                                                                                                              \u001b[21;13H\u001b(B\u001b[m\u001b[38;2;86;92;100m\u001b[48;2;30;34;42m(\"Or use shortcuts F5/F10/F11\")\u001b(B\u001b[m\u001b[38;2;171;178;191m\u001b[48;2;30;34;42m                                                                                                               \u001b[22;13H                  
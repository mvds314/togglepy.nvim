;27;31;39m                                                                                                                                              \u001b(B\u001b[m\u001b[38;2;171;178;191m\u001b[48;2;30;34;42m \u001b[32;12H\u001b(B\u001b[m\u001b[38;2;86;92;100m\u001b[48;2;30;34;42mt\u001b(B\u001b[m\u001b[38;2;171;178;191m\u001b[48;2;27;31;39m                                                                                                                                              \u001b(B\u001b[m\u001b[38;2;171;178;191m\u001b[48;2;30;34;42m \u001b[33;12H \u001b(B\u001b[m\u001b[38;2;171;178;191m\u001b[48;2;27;31;39m                                                                                                                                              \u001b(B\u001b[m\u001b[38;2;171;178;191m\u001b[48;2;30;34;42m \u001b[34;12H\u001b(B\u001b[m\u001b[38;2;86;92;100m\u001b[48;2;30;34;42mt\u001b(B\u001b[m\u001b[38;2;171;178;191m\u001b[48;2;27;31;39m                                                                                                                                              \u001b(B\u001b[m\u001b[38;2;171;178;191m\u001b[48;2;30;34;42m \u001b[35;12H\u001b(B\u001b[m\u001b[38;2;84;88;98m\u001b[48;2;30;34;42m \u001b(B\u001b[m\u001b[38;2;171;178;191m\u001b[48;2;27;31;39m                                                                                                                                              \u001b(B\u001b[m\u001b[38;2;84;88;98m\u001b[48;2;30;34;42m \u001b[36;12H \u001b(B\u001b[m\u001b[38;2;171;178;191m\u001b[48;2;27;31;39m                                                                                                                                              \u001b(B\u001b[m\u001b[38;2;84;88;98m\u001b[48;2;30;34;42m \u001b[37;12H \u001b(B\u001b[m\u001b[38;2;171;178;191m\u001b[48;2;27;31;39m                                                                                                                                              \u00